@model IEnumerable<Tech_FIX_API.Models.Quotation>

@{
    ViewBag.Title = "GetQuotation";
}

<br />
<h2 class="text-center">VIEW AVAILABLE QUOTATIONS</h2>

<br />
<br />
<table class="table table-centered">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.Description)</th>
            <th>@Html.DisplayNameFor(model => model.QuotationPrice)</th>
            <th>@Html.DisplayNameFor(model => model.QuotaQuantity)</th>
            <th>@Html.DisplayNameFor(model => model.OverAllDiscount)</th>
            <th>Action</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Description)</td>
                <td>@Html.DisplayFor(modelItem => item.QuotationPrice)</td>
                <td>@Html.DisplayFor(modelItem => item.QuotaQuantity)</td>
                <td>@Html.DisplayFor(modelItem => item.OverAllDiscount)</td>
                <td>
                    @Html.ActionLink("Order Now", "AddOrder", new { id = item.QuoteID }, new { @class = "btn btn-create" })
                </td>
            </tr>
        }
    </tbody>
</table>

<style>
    /* Button Styles */
    .btn-create {
        background-color: blue;
        color: white;
        padding: 10px 15px;
        border-radius: 5px;
        text-decoration: none;
    }

    .btn-edit {
        background-color: green;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
        text-decoration: none;
    }

    .btn-delete {
        background-color: red;
        color: white;
        padding: 5px 10px;
        border-radius: 5px;
        text-decoration: none;
    }

    /* Table Styles */
    .table-centered th, .table-centered td {
        text-align: center;
    }

    .table-centered th {
        background-color: darkblue;
        color: white;
    }
</style>

<!-- Footer Section -->
<footer style="background-color: black; color: white; text-align: center; padding: 10px;">
    www.techfix.com
</footer>
